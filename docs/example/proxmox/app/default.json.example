{
  "port": 5000,
  "command": "poll",
  "command2": "openpoll",
  "bot_name": "Open Poll Plus",
  "app_lang": "en",
  "app_lang_user_selectable": true,
  "app_allow_dm": true,
  "app_datetime_format": "YYYY-MM-DDTHH:mm:ssZ (ddd)",
  "slack_limit_choices": 15,
  "use_response_url": true,
  "menu_at_the_end": false,
  "create_via_cmd_only": false,
  "add_number_emoji_to_choice": true,
  "add_number_emoji_to_choice_btn": true,
  "help_link": "https://github.com/polppol/openpollslack-i18n",
  "help_email": "https://github.com/polppol/openpollslack-i18n",
  "compact_ui": true,
  "show_divider": true,
  "show_help_link": true,
  "show_command_info": false,
  "true_anonymous": true,

  "client_id": "REPLACE_WITH_SLACK_CLIENT_ID",
  "client_secret": "REPLACE_WITH_SLACK_CLIENT_SECRET",
  "signing_secret": "REPLACE_WITH_SLACK_SIGNING_SECRET",
  "state_secret": "REPLACE_WITH_ANY_RANDOM_STRING",
  "oauth_success": "https://poll.example.com/?oauth=success",
  "oauth_failure": "https://poll.example.com/?oauth=error",
  "support_url": "https://www.buymeacoffee.com/polppol",

  "mongo_url": "mongodb://openpoll:REPLACE_WITH_APP_DB_PASSWORD@10.100.51.42:27017/open_poll?authSource=open_poll",
  "mongo_db_name": "open_poll",

  "delete_data_on_poll_delete": true,
  "enable_poll_edit": true,
  "enable_poll_edit_max_mins": 60,
  "enable_poll_edit_keep_votes": true,
  "enable_rich_text_input": true,
  "log_level_app": "info",
  "log_level_app_file": "info",
  "log_level_bolt": "info",
  "log_level_bolt_file": "info",
  "log_to_file": true,
  "log_dir": "logs",
  "log_max_files": "360d",
  "schedule_limit_hrs": 11,
  "schedule_max_run": 365,
  "schedule_auto_delete_invalid_day": 30,
  "display_poller_name": "tag"
}
